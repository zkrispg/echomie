# ============================================================
# EchoMie Production Environment Variables
# Copy this to .env and fill in real values before deploying
# ============================================================

# --- Database (PostgreSQL) ---
DB_USER=echomie
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
DB_NAME=echomie

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- JWT (generate with: openssl rand -hex 32) ---
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# --- Internal worker token (generate with: openssl rand -hex 16) ---
INTERNAL_TOKEN=CHANGE_ME_INTERNAL_TOKEN

# --- App port (80 for HTTP, 443 if using SSL termination elsewhere) ---
APP_PORT=80

# --- DashScope / Qwen AI API Key ---
DASHSCOPE_API_KEY=CHANGE_ME_YOUR_DASHSCOPE_API_KEY

# --- SMTP (optional, for password reset emails) ---
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USER=your_email@qq.com
# SMTP_PASSWORD=your_smtp_auth_code
# SMTP_FROM=your_email@qq.com
