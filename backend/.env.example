# ============================
# Database
# ============================
# SQLite (default, zero-config):
# DATABASE_URL=sqlite:///C:/Users/yourname/backend-app.db
#
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/appdb

# ============================
# JWT / Auth
# ============================
JWT_SECRET_KEY=change-me-to-a-strong-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
RESET_TOKEN_EXPIRE_MINUTES=30

# ============================
# Redis
# ============================
REDIS_URL=redis://localhost:6379/0
USE_REDIS_QUEUE=0
REDIS_QUEUE_NAME=ai_tasks

# ============================
# Internal (Worker <-> Backend)
# ============================
INTERNAL_TOKEN=change-me-internal-secret
BACKEND_BASE_URL=http://127.0.0.1:8000

# ============================
# Storage
# ============================
# STORAGE_BASE_PATH=C:/Users/yourname/backend-storage
MAX_UPLOAD_SIZE_MB=500

# ============================
# SMTP (Email)
# ============================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=1
SMTP_USE_SSL=0

# ============================
# Password reset code
# ============================
PWD_RESET_CODE_TTL_SECONDS=600
PWD_RESET_CODE_COOLDOWN_SECONDS=60

# ============================
# Logging
# ============================
LOG_LEVEL=INFO
