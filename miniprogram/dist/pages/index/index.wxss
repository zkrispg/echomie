.home-page{max-width:100%}.home-greeting{margin-bottom:40rpx}.greeting-text{display:block;font-size:40rpx;font-weight:800}.home-affirmation{background:-webkit-linear-gradient(315deg,#f3edfc,#fff3ee);background:linear-gradient(135deg,#f3edfc,#fff3ee);border-left:8rpx solid #9b7ecb;border-radius:28rpx;font-size:28rpx;line-height:1.6;margin-top:24rpx;padding:28rpx 36rpx}.section{margin-bottom:40rpx}.section-title{display:block;font-size:32rpx;font-weight:700;margin-bottom:24rpx}.section-header{-ms-flex-pack:justify;-ms-flex-align:center;-webkit-align-items:center;align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;justify-content:space-between;margin-bottom:24rpx}.section-link{color:#9b7ecb;font-size:26rpx;font-weight:600}.mood-grid{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap;gap:16rpx}.mood-btn{-ms-flex-align:center;-webkit-align-items:center;align-items:center;background:#faf5f0;border:4rpx solid #ece4da;border-radius:28rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:8rpx;padding:24rpx 28rpx}.mood-btn.active{background:#f3edfc;border-color:#9b7ecb;-webkit-box-shadow:0 8rpx 24rpx rgba(155,126,203,.15);box-shadow:0 8rpx 24rpx rgba(155,126,203,.15)}.mood-emoji{font-size:52rpx}.mood-label{color:#6b5e7b;font-size:24rpx;font-weight:600}.empty-hint{padding:48rpx;text-align:center}.recent-grid{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:20rpx}.recent-card{-ms-flex-align:center;-webkit-align-items:center;align-items:center;background:#fff;border-radius:28rpx;-webkit-box-shadow:0 4rpx 16rpx rgba(155,126,203,.06);box-shadow:0 4rpx 16rpx rgba(155,126,203,.06);display:-webkit-flex;display:-ms-flexbox;display:flex;gap:24rpx;padding:20rpx 24rpx}.recent-thumb{-ms-flex-negative:0;border-radius:16rpx;-webkit-flex-shrink:0;flex-shrink:0;height:100rpx;width:100rpx}.recent-body{-ms-flex-align:center;-webkit-align-items:center;align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1;-ms-flex:1;flex:1;gap:16rpx;min-width:0}.recent-emoji{-ms-flex-negative:0;-webkit-flex-shrink:0;flex-shrink:0;font-size:40rpx}.recent-title{font-size:28rpx;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}