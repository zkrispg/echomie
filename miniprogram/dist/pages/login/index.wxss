.login-page{-ms-flex-align:center;-ms-flex-pack:center;-webkit-align-items:center;align-items:center;background:-webkit-linear-gradient(315deg,#e8d5f5,#fce4d6 50%,#d4eaf7);background:linear-gradient(135deg,#e8d5f5,#fce4d6 50%,#d4eaf7);display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:center;justify-content:center;min-height:100vh;padding:48rpx}.login-card{background:#fff;border-radius:56rpx;-webkit-box-shadow:0 16rpx 80rpx rgba(155,126,203,.14);box-shadow:0 16rpx 80rpx rgba(155,126,203,.14);padding:80rpx 60rpx;text-align:center;width:100%}.login-logo{display:block;font-size:120rpx;margin-bottom:8rpx}.login-title{color:#9b7ecb;display:block;font-size:52rpx;font-weight:800}.login-subtitle{color:#a89bb5;display:block;font-size:28rpx;margin:8rpx 0 48rpx}.login-btn{background:#9b7ecb!important;border:none;border-radius:28rpx;color:#fff!important;font-size:32rpx;font-weight:700;padding:28rpx 0;width:100%}.login-btn::after{display:none}