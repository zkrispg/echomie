.profile-page{padding-bottom:60rpx}.profile-header{margin-bottom:40rpx;text-align:center}.avatar-circle{-ms-flex-align:center;-ms-flex-pack:center;-webkit-align-items:center;align-items:center;background:-webkit-linear-gradient(315deg,#f3edfc,#fff3ee);background:linear-gradient(135deg,#f3edfc,#fff3ee);border:6rpx solid #f3edfc;border-radius:50%;display:-webkit-flex;display:-ms-flexbox;display:flex;height:140rpx;-webkit-justify-content:center;justify-content:center;margin:0 auto;width:140rpx}.avatar-text{font-size:64rpx}.avatar-picker{-ms-flex-pack:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap;gap:12rpx;-webkit-justify-content:center;justify-content:center;margin-top:20rpx}.avatar-opt{border:4rpx solid transparent;border-radius:50%;font-size:44rpx;padding:8rpx}.avatar-opt.active{background:#f3edfc;border-color:#9b7ecb}.profile-name{display:block;font-size:36rpx;font-weight:800;margin-top:20rpx}.profile-email{color:#a89bb5;display:block;font-size:26rpx;margin-top:4rpx}.form-group{margin-bottom:24rpx}.form-label{color:#6b5e7b;display:block;font-size:26rpx;font-weight:600;margin-bottom:8rpx}.form-input{background:#faf5f0;border:3rpx solid #ece4da;border-radius:16rpx;-webkit-box-sizing:border-box;box-sizing:border-box;font-size:28rpx;padding:20rpx 28rpx;width:100%}.mood-item{-ms-flex-align:start;-webkit-align-items:flex-start;align-items:flex-start;display:-webkit-flex;display:-ms-flexbox;display:flex;gap:20rpx;margin-bottom:24rpx}.mood-item-emoji{-ms-flex-negative:0;-webkit-flex-shrink:0;flex-shrink:0;font-size:44rpx}.mood-item-body{-webkit-flex:1;-ms-flex:1;flex:1}.mood-item-label{display:block;font-size:26rpx;font-weight:700;text-transform:capitalize}.mood-item-time{color:#a89bb5;font-size:22rpx}