.weekly-page{padding-bottom:40rpx}.header-row{-ms-flex-pack:justify;-ms-flex-align:center;-webkit-align-items:center;align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;justify-content:space-between;margin-bottom:32rpx}.page-title{font-size:36rpx;font-weight:800}.gen-btn{border-radius:16rpx;padding:16rpx 28rpx}.gen-btn.disabled{opacity:.5}.weekly-list{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:28rpx}.weekly-card{background:#fff;border-left:8rpx solid #9b7ecb;border-radius:28rpx;-webkit-box-shadow:0 4rpx 16rpx rgba(155,126,203,.06);box-shadow:0 4rpx 16rpx rgba(155,126,203,.06);padding:32rpx 36rpx}.weekly-range{display:block;font-size:28rpx;font-weight:700;margin-bottom:20rpx}.weekly-text{display:block;font-size:28rpx;line-height:1.7;margin-bottom:16rpx;white-space:pre-wrap}.weekly-trend{color:#6b5e7b;display:block;font-size:24rpx;margin-bottom:20rpx}.weekly-tags{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap;gap:12rpx;margin-bottom:20rpx}.weekly-tag{background:#f3edfc;border:2rpx solid rgba(155,126,203,.25);border-radius:40rpx;color:#9b7ecb;font-size:22rpx;font-weight:600;padding:8rpx 24rpx}.weekly-enc{background:-webkit-linear-gradient(315deg,#edf8f0,#f3edfc);background:linear-gradient(135deg,#edf8f0,#f3edfc);border:2rpx solid #a7e6b8;border-radius:16rpx;font-size:26rpx;line-height:1.6;padding:24rpx 28rpx}